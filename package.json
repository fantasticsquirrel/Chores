{
  "name": "chore_tracking",
  "version": "1.0.7",
  "private": true,
  "workspaces": [
    "frontend",
    "mobile",
    "packages/*"
  ],
  "overrides": {
    "xcode": {
      "uuid": "^11.1.1"
    }
  },
  "scripts": {
    "lint": "npm run lint --workspace frontend",
    "test": "npm run test --workspace frontend",
    "build": "npm run build --workspace frontend",
    "mobile:start": "npm run start --workspace mobile",
    "mobile:android": "npm run android --workspace mobile",
    "mobile:ios": "npm run ios --workspace mobile",
    "mobile:typecheck": "npm run typecheck --workspace mobile",
    "mobile:test": "npm run test --workspace mobile",
    "mobile:gate": "npm run mobile:typecheck && npm run mobile:test && cd mobile && npx expo install --check",
    "mobile:apk": "npm run apk --workspace mobile",
    "mobile:apk:local": "npm run apk:local --workspace mobile",
    "mobile:eas:init": "npm run eas:init --workspace mobile",
    "mobile:eas:set-api": "npm run eas:set-api --workspace mobile --",
    "mobile:eas:whoami": "npm run eas:whoami --workspace mobile"
  },
  "devDependencies": {
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  }
}
