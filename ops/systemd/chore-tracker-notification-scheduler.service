[Unit]
Description=Generate Family Manager scheduled notifications
After=network.target

[Service]
Type=oneshot
User=www-data
Group=www-data
WorkingDirectory=/var/ralph-projects/chore_tracking/backend
EnvironmentFile=/etc/chore-tracker/chore-tracker.env
ExecStart=/var/ralph-projects/chore_tracking/.venv/bin/python -m scripts.run_notification_scheduler
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/ralph-projects/chore_tracking/data
