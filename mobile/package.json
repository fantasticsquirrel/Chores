{
  "name": "@family-manager/mobile",
  "version": "1.0.7",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~56.0.17",
    "@family-manager/family-api": "file:../packages/family-api",
    "expo": "~56.0.16",
    "expo-modules-core": "~56.0.21",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.2",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --environment node --exclude 'src/**/*.test.tsx'",
    "test:ui": "jest --runInBand",
    "test": "npm run test:unit && npm run test:ui",
    "apk": "bash ./scripts/build-apk.sh",
    "apk:local": "bash ./scripts/build-apk.sh --local",
    "eas:init": "npx --yes eas-cli@20.0.0 project:init",
    "eas:set-api": "bash ./scripts/set-eas-api-url.sh",
    "eas:whoami": "npx --yes eas-cli@20.0.0 whoami"
  },
  "private": true
}
